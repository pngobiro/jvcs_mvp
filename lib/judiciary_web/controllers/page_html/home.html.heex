<div class="px-4 py-10 sm:px-6 sm:py-28 lg:px-8 xl:px-28 xl:py-32 bg-zinc-50 min-h-[calc(100vh-80px)] relative">
  <div class="absolute top-4 right-4 sm:top-8 sm:right-8 flex gap-4">
    <%= if @current_scope && @current_scope.user do %>
      <.link href={~p"/users/settings"} class="text-[10px] font-black uppercase tracking-widest text-zinc-500 hover:text-judiciary-green transition-colors px-4 py-2 border border-zinc-200 rounded-lg bg-white">
        {@current_scope.user.email}
      </.link>
      <.link href={~p"/users/log_out"} method="delete" class="text-[10px] font-black uppercase tracking-widest text-white hover:bg-red-700 transition-colors px-4 py-2 border border-red-600 rounded-lg bg-red-600">
        Log out
      </.link>
    <% else %>
      <.link href={~p"/users/log_in"} class="text-[10px] font-black uppercase tracking-widest text-white hover:bg-judiciary-green-dark transition-colors px-6 py-2 border border-judiciary-green rounded-lg bg-judiciary-green shadow-sm">
        Log in
      </.link>
    <% end %>
  </div>

  <div class="mx-auto max-w-2xl text-center">
    <div class="flex justify-center mb-10">
      <div class="p-4 bg-white rounded-3xl shadow-2xl border-b-4 border-judiciary-gold">
        <img src={~p"/images/judiciary-logo.png"} class="h-32 w-auto object-contain" alt="Judiciary Logo Large" />
      </div>
    </div>
    
    <h1 class="text-4xl font-black tracking-tight text-zinc-900 sm:text-6xl uppercase leading-none">
      Judiciary <span class="text-judiciary-green">Virtual Court</span> System
    </h1>
    
    <div class="mt-4 flex items-center justify-center gap-2">
      <span class="h-px w-8 bg-judiciary-gold"></span>
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-zinc-400">Republic of Kenya</span>
      <span class="h-px w-8 bg-judiciary-gold"></span>
    </div>

    <p class="mt-8 text-lg leading-8 text-zinc-600 font-medium">
      Welcome to the J-VCS. This platform facilitates digital court sessions, ensuring justice is accessible, secure, and sovereign for all citizens.
    </p>
    
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-6">
      <.link
        href={~p"/activities"}
        class="w-full sm:w-auto rounded-2xl bg-judiciary-green px-8 py-4 text-sm font-black text-white shadow-xl hover:bg-judiciary-green-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-judiciary-green transition-all active:scale-[0.98] border-b-4 border-judiciary-gold uppercase tracking-widest"
      >
        View Court Causelist
      </.link>
      <a href="https://github.com/pngobiro/jvcs_mvp" class="text-sm font-bold leading-6 text-zinc-500 hover:text-judiciary-green transition-colors">
        Documentation <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</div>